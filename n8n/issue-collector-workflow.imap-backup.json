    {
      "parameters": {
        "functionCode": "const today = new Date().toISOString().split('T')[0];\nconst staticData = $getWorkflowStaticData('global');\nif (staticData.countDate !== today) {\n  staticData.countDate = today;\n  staticData.dailyCount = 0;\n}\nreturn [{ json: { ...items[0].json, dailyTicketCount: staticData.dailyCount, todayDate: today } }];"
      },
      "id": "count-checker",
      "name": "📊 Tageszähler prüfen",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        640,
        320
      ]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.dailyTicketCount }}",
              "operation": "smallerEqual",
              "value2": 10
            }
          ]
        }
      },
      "id": "throttle-check",
      "name": "🛡️ Throttle Check (max 10/Tag)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        860,
        320
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyContentType": "json",
        "jsonBody": "={{ JSON.stringify({\"model\": \"llama-3.3-70b-versatile\",\"temperature\": 0.3,\"messages\": [{\"role\": \"system\", \"content\": \"Du bist ein KI-Assistent der Feature Requests und Bug-Reports analysiert. Antworte NUR mit einem JSON-Objekt ohne Markdown-Blocke.\\\\n\\\\nFormat:\\\\n{\\\\n  \\\\\\\"title\\\\\\\": \\\\\\\"Praegnanter Titel (max 60 Zeichen)\\\\\\\",\\\\n  \\\\\\\"category\\\\\\\": \\\\\\\"technical | user-story | bug\\\\\\\",\\\\n  \\\\\\\"priority\\\\\\\": \\\\\\\"urgent | medium | low\\\\\\\",\\\\n  \\\\\\\"deadline\\\\\\\": \\\\\\\"YYYY-MM-DD oder null\\\\\\\",\\\\n  \\\\\\\"description\\\\\\\": \\\\\\\"Aufbereitete Beschreibung des Anliegens\\\\\\\",\\\\n  \\\\\\\"subtasks\\\\\\\": [\\\\\\\"Konkreter Umsetzungsschritt 1\\\\\\\", \\\\\\\"Konkreter Umsetzungsschritt 2\\\\\\\"]\\\\n}\\\\n\\\\nSubtask-Regeln:\\\\n- Nur konkrete, umsetzbare Schritte als Subtasks (max. 4, je max. 60 Zeichen)\\\\n- Kein allgemeiner Text - Subtasks sind Aufgaben, keine Beschreibungen\\\\n- Leeres Array [] wenn keine sinnvollen Schritte ableitbar sind\\\\n\\\\nPrioritaet-Regeln:\\\\n- urgent: kritisch, dringend, blockiert, crash\\\\n- low: nice to have, irgendwann, optional\\\\n- medium: Standard\"},{\"role\": \"user\", \"content\": \"Analysiere diese E-Mail:\\\\n\\\\nVon: \" + $json.from + \"\\\\nBetreff: \" + $json.subject + \"\\\\n\\\\nInhalt:\\\\n\" + ($json.text || $json.html || '')}]}) }}"
      },
      "id": "groq-ai",
      "name": "🤖 KI-Analyse (Groq)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1100,
        200
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "GROQ_CREDENTIAL_ID",
          "name": "Groq API"
        }
      }
    },
    {
      "parameters": {
        "functionCode": "// output[0] = Erfolg  |  output[1] = Fehler\ntry {\n  const aiResponse = items[0].json.choices[0].message.content;\n  let parsed;\n  try { parsed = JSON.parse(aiResponse); }\n  catch (e) { parsed = { title: 'Neues Ticket', category: 'technical', priority: 'medium', deadline: null, description: '', subtasks: [] }; }\n\n  const emailData = $items('📧 E-Mail Empfang (IMAP)')[0].json;\n  const bodyText = emailData.text || emailData.html || '';\n  const senderMatch = bodyText.match(/REPLY_TO_EMAIL:\\s*([^\\n\\r<]+)/i);\n  const emailRegex = /[\\w.+\\-]+@[\\w\\-]+\\.[\\w.]+/;\n  const fromRaw = emailData.replyTo || emailData.from || '';\n  const fromMatch = fromRaw.match(emailRegex);\n  const senderEmail = (senderMatch && senderMatch[1].trim())\n    || (fromMatch && fromMatch[0])\n    || fromRaw.replace(/^[\"'\\s<>]+|[\"'\\s<>]+$/g, '').trim();\n\n  const kiHinweis = '\\n\\n---\\n⚠️ KI-generiert aus E-Mail von: ' + senderEmail;\n\n  const rawSubtasks = Array.isArray(parsed.subtasks) ? parsed.subtasks : [];\n  const subtasks = rawSubtasks\n    .filter(function(t) { return typeof t === 'string' && t.trim().length > 0; })\n    .slice(0, 4)\n    .map(function(t, i) { return { id: Date.now() + i, text: t.trim(), completed: false }; });\n\n  return [[{ json: {\n    title: parsed.title,\n    category: parsed.category || 'technical',\n    priority: parsed.priority || 'medium',\n    deadline: parsed.deadline,\n    description: (parsed.description || '') + kiHinweis,\n    subtasks: subtasks,\n    senderEmail: senderEmail,\n    originalSubject: emailData.subject\n  }}], []];\n} catch (e) {\n  const emailData = items[0].json;\n  const fromRaw = emailData.replyTo || emailData.from || '';\n  const fromMatch = fromRaw.match(/[\\w.+\\-]+@[\\w\\-]+\\.[\\w.]+/);\n  return [[], [{ json: { error: e.message, senderEmail: (fromMatch && fromMatch[0]) || 'unknown' } }]];\n}"
      },
      "id": "parse-ai-response",
      "name": "🔧 KI-Antwort aufbereiten",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1320,
        200
      ]
    },
