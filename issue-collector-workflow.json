      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [
        900,
        420
      ],
      "parameters": {
        "fromEmail": "DEINE_GMAIL_ADRESSE@gmail.com",
        "toEmail": "={{ $('📧 E-Mail Empfang (IMAP)').item.json.from }}",
        "subject": "⚠️ Dein Feature Request konnte nicht verarbeitet werden",
        "emailType": "html",
        "message": "<html><body style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;\">\n<div style=\"background: #2A3647; padding: 20px; border-radius: 8px 8px 0 0;\">\n  <h1 style=\"color: white; margin: 0;\">Join – Issue Collector</h1>\n</div>\n<div style=\"border: 1px solid #ddd; padding: 20px; border-radius: 0 0 8px 8px;\">\n  <h2 style=\"color: #FF8190;\">Verarbeitungsfehler</h2>\n  <p>Leider konnte dein Feature Request aufgrund eines technischen Fehlers nicht verarbeitet werden.</p>\n  <p>Unser Team hat deine E-Mail erhalten und wird sich zeitnah melden.</p>\n  <p style=\"color: #666; font-size: 14px;\">Bitte wende dich direkt an das Team, falls du innerhalb von 24 Stunden keine Rückmeldung erhältst.</p>\n</div>\n</body></html>"
      },
      "credentials": {}
    }
  ],
